# Trend Micro Vision One API credentials
# Get your API key from: Vision One Console > Administration > API Keys
# Ensure the key has permissions for: Sandbox Analysis, File Security, AI Guard, Threat Intelligence

V1_API_TOKEN=your-vision-one-api-token-here

# Region where your Vision One tenant is hosted
# Valid regions: ap-northeast-1, ap-south-1, ap-southeast-1, ap-southeast-2,
#                ca-central-1, eu-central-1, eu-west-2, me-south-1, us-east-1
V1_REGION=us-east-1
